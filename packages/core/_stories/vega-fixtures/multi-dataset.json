{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "Weekly Incident Case Counts"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "color": "#3f82e0"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Date (CCCD)",
          "axis": {
            "labelExpr": "[utcFormat(datum.value, '%b'), utcFormat(datum.value, '%m') == '01' ? utcFormat(datum.value, '%Y') : '']"
          },
          "scale": {
            "nice": "month"
          }
        },
        "y": {
          "field": "sum of cases",
          "type": "quantitative",
          "title": "Total Number of Cases",
          "scale": {
            "domain": {
              "unionWith": [
                0,
                1
              ]
            }
          }
        },
        "color": {
          "value": "#578edb",
          "legend": {
            "title": "Legend"
          }
        }
      }
    },
    {
      "data": {
        "name": "3 week moving average"
      },
      "mark": {
        "type": "line",
        "color": "black",
        "strokeDash": [
          4,
          4
        ]
      },
      "encoding": {
        "x": {
          "field": "test",
          "type": "temporal",
          "title": "Date (CCCD)",
          "scale": {
            "nice": "month"
          }
        },
        "y": {
          "field": "rate",
          "type": "quantitative",
          "title": "Total Number of Cases",
          "scale": {
            "domain": {
              "unionWith": [
                0,
                1
              ]
            }
          }
        },
        "color": {
          "value": "black",
          "legend": {
            "title": "Legend"
          }
        }
      }
    }
  ],
