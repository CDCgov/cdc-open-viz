{
  "data": {
    "name": "data"
  },
  "params": [
    {
      "name": "dateExtent",
      "expr": "extent(pluck(data('data_0'), 'date'))"
    },
    {
      "name": "dateMax",
      "expr": "dateExtent[1]"
    }
  ],
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "timeUnit": "yearmonth",
          "title": "Month of Report",
          "axis": {
            "format": "%b %Y",
            "grid": false
          }
        },
        "y": {
          "aggregate": "sum",
          "field": "measlesTotal",
          "title": "Number of Cases"
        },
        "color": {
          "field": "whoRegion",
          "title": "WHO Region",
          "scale": {
            "domain": [
              "AFRO",
              "AMRO",
              "EMRO",
              "EURO",
              "SEARO",
              "WPRO"
            ],
            "range": [
              "#2D72D2",
              "#DB2C6F",
              "#8EB125",
              "#9D3F9D",
              "#00A396",
              "#D1980B"
            ]
          },
          "legend": {
            "orient": "top"
          }
        },
        "tooltip": [
          {
            "field": "whoRegion",
            "title": "WHO Region"
          },
          {
            "field": "date",
            "type": "temporal",
            "title": "Month",
            "format": "%b %Y"
          },
          {
            "field": "sum_measlesTotal",
            "title": "Number of Cases",
            "type": "quantitative",
            "format": ","
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.date < dateMax"
        },
        {
          "calculate": "timeOffset('day', datum.date, 14)",
          "as": "date_shifted"
        },
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "measlesTotal",
              "as": "cases"
            }
          ],
          "groupby": [
            "date",
            "date_shifted"
          ]
        },
        {
          "window": [
            {
              "op": "mean",
              "field": "cases",
              "as": "cases_smooth"
            }
          ],
          "frame": [
            -1,
            1
          ],
          "sort": [
            {
              "field": "date_shifted",
              "order": "ascending"
            }
          ]
        }
      ],
      "mark": {
        "type": "line",
        "color": "black",
        "strokeWidth": 2,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "date_shifted",
          "type": "temporal"
        },
        "y": {
          "aggregate": "sum",
          "field": "cases_smooth"
        },
        "strokeWidth": {
          "datum": "3-month average (all cases)",
          "title": " ",
          "legend": {
            "labelLimit": 250,
            "orient": "top"
          }
        },
        "tooltip": [
          {
            "field": "cases_smooth",
            "title": "Moving Average",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "height": "container",
  "width": "container",
