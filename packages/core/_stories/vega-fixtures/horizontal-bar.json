          "type": "aggregate",
          "groupby": [
            "Director"
          ],
          "ops": [
            "average"
          ],
          "fields": [
            "Worldwide Gross"
          ],
          "as": [
            "Gross"
          ]
        },
        {
          "type": "window",
          "sort": {
            "field": "Gross",
            "order": "descending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rank <= k"
        }
      ]
