      },
      "series": [
        {
          "dataKey": "Value"
        }
      ],
      "theme": "theme-blue"
    },
    "chart-empty-dataset": {
      "uid": "chart-empty-dataset",
      "type": "chart",
      "visualizationType": "Bar",
      "title": "Empty dataset",
