{
  "type": "dashboard",
  "version": "4.26.5",
  "dashboard": {
    "theme": "theme-blue",
    "title": "Regression: Missing Datasets (Single Dashboard)",
    "description": "<p>This fixture intentionally mixes a missing dataset key and an empty dataset so dashboard loading can skip dataset preparation safely.</p>"
  },
  "rows": [
