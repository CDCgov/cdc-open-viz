      "xAxis": {
        "dataKey": "Category"
      },
      "series": [
        {
          "dataKey": "Value"
        }
      ],
      "theme": "theme-blue"
    },
    "chart-row-missing-dataset": {
      "uid": "chart-row-missing-dataset",
      "type": "chart",
      "visualizationType": "Bar",
      "title": "Row with missing dataset",
      "xAxis": {
        "dataKey": "Category"
      },
      "series": [
        {
          "dataKey": "Value"
        }
      ],
      "theme": "theme-blue"
    }
