      {
        "key": "Region",
        "label": "Region",
        "type": "datafilter",
        "filterStyle": "dropdown",
        "columnName": "Region",
        "showDropdown": true,
        "active": "North",
        "values": ["North", "South"],
        "orderedValues": ["North", "South"],
        "usedBy": ["chart-alpha", "chart-beta", "chart-gamma", "missing-widget"],
        "resetLabel": "Select a region"
      },
      {
        "key": "Status",
        "label": "Status",
        "type": "datafilter",
        "filterStyle": "dropdown",
        "columnName": "Status",
        "showDropdown": true,
        "active": "Open",
        "values": ["Open", "Closed"],
        "orderedValues": ["Open", "Closed"],
        "usedBy": ["chart-alpha", "chart-beta", "missing-widget-2"],
        "resetLabel": "Select a status"
      },
      {
        "key": "Year",
        "label": "Year",
        "type": "datafilter",
        "filterStyle": "dropdown",
        "columnName": "Year",
        "showDropdown": true,
        "active": "2024",
        "values": ["2023", "2024"],
        "orderedValues": ["2023", "2024"],
        "usedBy": ["chart-gamma"],
        "resetLabel": "Select a year"
      }
    ]
  },
