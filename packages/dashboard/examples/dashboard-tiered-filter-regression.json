          "Value": 12
        },
        {
          "Region": "North",
          "Category": "Beta",
          "Detail": "One",
          "Label": "North Beta One",
          "Value": 13
        },
        {
          "Region": "South",
          "Category": "Alpha",
          "Detail": "One",
          "Label": "South Alpha One",
          "Value": 21
        },
        {
          "Region": "South",
          "Category": "Beta",
          "Detail": "Two",
          "Label": "South Beta Two",
          "Value": 22
