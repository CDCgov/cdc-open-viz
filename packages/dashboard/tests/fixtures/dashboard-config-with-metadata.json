      "enableMarkupVariables": true,
      "markupVariables": [
        {
          "name": "Last Updated",
          "tag": "{{lastUpdated}}",
          "metadataKey": "lastUpdated",
          "conditions": []
        }
      ],
      "xAxis": { "dataKey": "Year" },
      "series": [{ "dataKey": "Amount", "type": "Bar" }],
      "dataKey": "metadata-test-data",
      "theme": "theme-blue"
